# Vercel production environment
NEXT_PUBLIC_APP_URL=https://careconnect-omega-one.vercel.app
NEXT_PUBLIC_BACKEND_URL=https://careconnect-backend-rud7.onrender.com
NEXT_PUBLIC_PRELAUNCH_SURVEY_MODE=true

# Use the same AUTH_SECRET and BACKEND_API_KEY values on Vercel and Render.
AUTH_SECRET=
BACKEND_API_KEY=

# Use the same MongoDB database as the Render backend.
DATABASE_URL=

# Required for profile photos and worker documents.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Required when the corresponding production features are enabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=gbp

BREVO_API_KEY=
BREVO_API_BASE_URL=https://api.brevo.com/v3
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=CareConnect

EBC_API_BASE_URL=
EBC_API_KEY=
EBC_WEBHOOK_SECRET=
